# Data/ policy (2026-07-15, audit #16 — user decision, supersedes G6):
# data files are NOT tracked going forward. The one-off G6 restore-point
# snapshot lives in history at commit 338e91a; daily scrapes rewrite these
# files, so tracking them grows git history by GBs per month.
Data/*
!Data/GLOSSARY.md
cache
backups
todays_games.json

editor/office junk
~$*
tempCodeRunnerFile*
Logs/
*.log
Predictions/

# trained model binaries are large and regenerable (Model/train.py);
# the small JSONs (metrics.json, eval baselines) stay committed as
# evidence of results
Model/artifacts/*
!Model/artifacts/*.json
*.joblib
*.pkl
*.pickle
*.pt
*.h5
*.onnx

# python
__pycache__/
*.pyc

# local/env files
.venv/
venv/
.env
.odds_api_key

# local tooling
.claude/
cache/
.vscode
